# Optional API key for future assistant integrations.
# The current frontend does not require this to run.
GEMINI_API_KEY=""

# Public Cognito OIDC configuration.
VITE_AWS_REGION="us-east-1"
VITE_COGNITO_USER_POOL_ID="us-east-1_vyONcitBD"
VITE_COGNITO_CLIENT_ID="7qmkq33si9qk8pgo6ebi3qantm"

# NFT service browser route and local Vite proxy target.
# The creator address is public; never place a Stellar secret key here.
VITE_NFT_API_URL="/api/nft"
NFT_API_PROXY_TARGET="http://127.0.0.1:4101"
VITE_STELLAR_OWNER_ADDRESS=""

# Server-only secret for the Morph/opencode chat proxy.
# Do not expose this as a VITE_* browser variable.
OPENCODE_PROVIDER="opencode zen"
OPENCODE_MODEL="big-opickle"
OPENCODE_API_KEY=""
# Optional override. Defaults to https://api.opencode.ai/v1/chat/completions.
OPENCODE_API_URL=""

# Public app URL used by future hosted previews and callbacks.
APP_URL="http://127.0.0.1:3000"
