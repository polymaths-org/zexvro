# Optional API key for future assistant integrations.
# The current frontend does not require this to run.
GEMINI_API_KEY=""

# Public Cognito OIDC configuration.
VITE_AWS_REGION="us-east-1"
VITE_COGNITO_USER_POOL_ID="us-east-1_vyONcitBD"
VITE_COGNITO_CLIENT_ID="7qmkq33si9qk8pgo6ebi3qantm"

# Server-only secret for the Morph/opencode chat proxy.
# Do not expose this as a VITE_* browser variable.
OPENCODE_PROVIDER="opencode zen"
OPENCODE_MODEL="big-opickle"
OPENCODE_API_KEY=""
# Optional override. Defaults to https://api.opencode.ai/v1/chat/completions.
OPENCODE_API_URL=""

# Public app URL used by future hosted previews and callbacks.
APP_URL="http://127.0.0.1:3000"

# Soroban multi-denom privacy pools (testnet) — few ZK notes for large pays
VITE_ZER0_CONTRACT="CDQSV7I3FRQ6EBQOOE6MQSJHPCPQNHPWRK2G75DYYOOOGHDVIQGOZF4I"
VITE_ZER0_CONTRACT_10="CBNQMLEYWUBYS2JJKGP7NIUK3QOXLBY774JWPXO6ZXONQMB3K5QYLMNW"
VITE_ZER0_CONTRACT_100="CDWPYRZVZT37LBB7DTPYV43WPXQZTS7QD6PXLGWO37GDVXVJ3JOJEJP5"
VITE_ZER0_CONTRACT_1000="CDOOUXPZCGIMKRQ2UQUGEMWFGC7X2V7BGNQTTBFWCQ4GVTHO44AGJUUP"
VITE_SOROBAN_RPC="https://soroban-testnet.stellar.org:443"

# Remote prove goes through API Gateway → Lambda → EC2 worker.
# Configure Lambda env (not VITE_*):
#   ZK_WORKER_INSTANCE_ID=i-xxxxxxxx
#   ZK_PROVER_URL=http://x.x.x.x:8787
#   ZK_PROVER_PORT=8787
#   ZK_PROVER_SHARED_SECRET=...
# Frontend uses existing VITE_API_URL + /api/zk-worker/*

# Local development prefers the repository-root `.env`.
# Copy `../.env.example` to `../.env` and run commands from the repo root:
#
#   npm run dev
#
# Keep this file for frontend-only flows and Zer0/Cognito overrides.

# Production App Runner endpoints (optional; leave relative /api/* for local proxy):
# VITE_NFT_API_URL="https://iyk6idmup6.us-east-1.awsapprunner.com"
# VITE_DEPIN_API_URL="https://sr9k3xpmbj.us-east-1.awsapprunner.com"
