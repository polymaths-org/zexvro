{
  "$schema": "https://opencode.ai/config.json",
  // Morph TUI host config (OpenCode engine).
  // Stock OpenCode providers remain available; Morph adds custom ones at launch.
  "default_agent": "morph",
  "theme": "morph",
  "autoupdate": false,
  "tools": {
    "bash": true,
    "edit": true,
    "read": true,
    "grep": true,
    "glob": true,
    "webfetch": true
  },
  "permission": {
    "bash": "ask",
    "edit": "ask",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "webfetch": "allow",
    "external_directory": "ask"
  },
  "mcp": {
    "zexvro": {
      "type": "local",
      "command": ["node", "{env:MORPH_MCP_ENTRY}"],
      "enabled": true,
      "environment": {
        "ZEXVRO_API_URL": "{env:ZEXVRO_API_URL}",
        "ZEXVRO_GATE_URL": "{env:ZEXVRO_GATE_URL}",
        "ZEXVRO_NFT_URL": "{env:ZEXVRO_NFT_URL}",
        "ZEXVRO_DEPIN_URL": "{env:ZEXVRO_DEPIN_URL}",
        "ZEXVRO_ACCESS_TOKEN": "{env:ZEXVRO_ACCESS_TOKEN}",
        "ZEXVRO_GATE_ADMIN_KEY": "{env:ZEXVRO_GATE_ADMIN_KEY}"
      }
    }
  }
}
