{
  "$schema": "https://opencode.ai/config.json",
  // Morph project config for OpenCode.
  // All stock OpenCode providers stay available (we do not disable them).
  // Optional custom OpenAI-compatible provider via ZEXVRO_LLM_* env vars.
  "default_agent": "morph",
  "tools": {
    "bash": true,
    "edit": true,
    "read": true,
    "grep": true,
    "glob": true,
    "webfetch": true
  },
  "permission": {
    "bash": "ask",
    "edit": "ask",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "webfetch": "allow",
    "external_directory": "ask"
  },
  "provider": {
    "zexvro": {
      "name": "ZEXVRO / custom OpenAI-compatible",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "{env:ZEXVRO_LLM_BASE_URL}",
        "apiKey": "{env:ZEXVRO_LLM_API_KEY}",
        "timeout": 600000
      },
      "models": {
        "default": {
          "name": "Custom model (ZEXVRO_LLM_BASE_URL)",
          "tool_call": true,
          "limit": {
            "context": 200000,
            "output": 16384
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    }
  },
  "mcp": {
    "zexvro": {
      "type": "local",
      "command": ["node", "mcp/src/index.mjs"],
      "enabled": true,
      "environment": {
        "ZEXVRO_API_URL": "{env:ZEXVRO_API_URL}",
        "ZEXVRO_GATE_URL": "{env:ZEXVRO_GATE_URL}",
        "ZEXVRO_NFT_URL": "{env:ZEXVRO_NFT_URL}",
        "ZEXVRO_DEPIN_URL": "{env:ZEXVRO_DEPIN_URL}",
        "ZEXVRO_ACCESS_TOKEN": "{env:ZEXVRO_ACCESS_TOKEN}",
        "ZEXVRO_GATE_ADMIN_KEY": "{env:ZEXVRO_GATE_ADMIN_KEY}"
      }
    }
  }
}
