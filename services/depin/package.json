{
  "name": "@zexvro/depin-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && tsc -p tsconfig.build.json",
    "demo:client": "tsx src/demoClient.ts",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src --max-warnings=0",
