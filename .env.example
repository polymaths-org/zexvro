# ZEXVRO root environment
#
# Copy this file to `.env` at the repository root. The root dev scripts load
# this file and pass the same environment to the frontend, NFT API, and optional
# De-pin gateway, so you do not need per-folder `.env` files for local work.

# Frontend / browser-safe values
APP_URL="http://127.0.0.1:3000"
VITE_AWS_REGION="us-east-1"
VITE_COGNITO_USER_POOL_ID="us-east-1_vyONcitBD"
VITE_COGNITO_CLIENT_ID="7qmkq33si9qk8pgo6ebi3qantm"
VITE_NFT_API_URL="/api/nft"
NFT_API_PROXY_TARGET="http://127.0.0.1:4101"
VITE_DEPIN_API_URL="/api/depin"
DEPIN_API_PROXY_TARGET="http://127.0.0.1:4102"
VITE_STELLAR_OWNER_ADDRESS=""
GEMINI_API_KEY=""

# Morph/opencode dev proxy. Server-side only: do not rename these to VITE_*.
OPENCODE_PROVIDER="opencode zen"
OPENCODE_MODEL="big-opickle"
OPENCODE_API_KEY=""
OPENCODE_API_URL=""

# NFT API
PORT=4101
NFT_DATA_FILE=".data/nft-service.json"
NFT_STORAGE_MODE="local"
NFT_LOCAL_ASSET_DIR=".data/assets"
NFT_PUBLIC_BASE_URL="http://127.0.0.1:4101"
PINATA_JWT=""
COGNITO_USER_POOL_ID="us-east-1_vyONcitBD"
COGNITO_CLIENT_ID="7qmkq33si9qk8pgo6ebi3qantm"
CORS_ALLOWED_ORIGINS="http://127.0.0.1:3000,http://localhost:3000"
STELLAR_RPC_URL="https://soroban-testnet.stellar.org"
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_USDC_CONTRACT="CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA"
NFT_CHECKOUT_TTL_SECONDS=300

# Local Stellar helper. If STELLAR_SPONSOR_SECRET is empty, `npm run dev`
# reads this identity from Stellar CLI at runtime and never writes the secret.
ZEXVRO_STELLAR_IDENTITY="zexvro-provider"
STELLAR_SPONSOR_SECRET=""
NFT_COLLECTION_WASM_HASH="a8a5f637131c4f5db91d682008b68f21ab2f4f87e0844866ac80fad9faab6bad"

# Optional De-pin gateway. `npm run dev` starts frontend + NFT API.
# Use `npm run dev:all` when you also want the De-pin gateway.
DEPIN_CONFIG_PATH="depin.config.json"
WEATHER_API_TOKEN=""

