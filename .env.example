# ZEXVRO root environment
#
# Copy this file to `.env` at the repository root. The root dev scripts load
# this file and pass the same environment to the frontend, NFT API, and optional
# De-pin gateway, so you do not need per-folder `.env` files for local work.

# Frontend / browser-safe values
APP_URL="http://127.0.0.1:3000"
VITE_AWS_REGION="us-east-1"
VITE_COGNITO_USER_POOL_ID="us-east-1_vyONcitBD"
VITE_COGNITO_CLIENT_ID="7qmkq33si9qk8pgo6ebi3qantm"
VITE_NFT_API_URL="/api/nft"
NFT_API_PROXY_TARGET="http://127.0.0.1:4101"
VITE_DEPIN_API_URL="/api/depin"
DEPIN_API_PROXY_TARGET="http://127.0.0.1:4102"
VITE_STELLAR_OWNER_ADDRESS=""
GEMINI_API_KEY=""

# Morph/opencode dev proxy. Server-side only: do not rename these to VITE_*.
OPENCODE_PROVIDER="opencode zen"
OPENCODE_MODEL="big-opickle"
OPENCODE_API_KEY=""
OPENCODE_API_URL=""

# NFT API
PORT=4101
NFT_DATA_FILE=".data/nft-service.json"
# file = local JSON (default). dynamo = multi-instance AWS DynamoDB table.
NFT_REPOSITORY="file"
NFT_DYNAMO_TABLE="zexvro-nft"
NFT_DYNAMO_REGION="us-east-1"
NFT_DYNAMO_GSI_WORKSPACE="workspace-index"
NFT_DYNAMO_GSI_IDEMPOTENCY="idempotency-index"
# local = content-addressed HTTP assets (dev only)
# s3 = production media on AWS S3 (+ optional CloudFront CDN base URL)
# pinata = optional legacy public IPFS (requires PINATA_JWT)
NFT_STORAGE_MODE="local"
NFT_LOCAL_ASSET_DIR=".data/assets"
NFT_PUBLIC_BASE_URL="http://127.0.0.1:4101"
NFT_S3_BUCKET=""
NFT_S3_REGION="us-east-1"
# Optional CloudFront or custom HTTPS origin for public object URLs
NFT_CDN_BASE_URL=""
# Optional legacy Pinata. Server-side only. Never commit a real JWT.
PINATA_JWT=""
COGNITO_USER_POOL_ID="us-east-1_vyONcitBD"
COGNITO_CLIENT_ID="7qmkq33si9qk8pgo6ebi3qantm"
# Comma-separated browser origins for NFT API CORS (studio + public buy + game embeds).
# Add each partner game origin explicitly, e.g. https://game.example.com
CORS_ALLOWED_ORIGINS="http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:4173,http://localhost:4173"
STELLAR_RPC_URL="https://soroban-testnet.stellar.org"
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_USDC_CONTRACT="CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA"
NFT_CHECKOUT_TTL_SECONDS=300

# Local Stellar helper. If STELLAR_SPONSOR_SECRET is empty, `npm run dev`
# reads this identity from Stellar CLI at runtime and never writes the secret.
# Hosted/production: inject STELLAR_SPONSOR_SECRET from Secrets Manager; do not
# rely on CLI identity. NODE_ENV=production (or NFT_REQUIRE_SPONSOR=1) fails fast
# without STELLAR_SPONSOR_SECRET + NFT_COLLECTION_WASM_HASH.
ZEXVRO_STELLAR_IDENTITY="zexvro-provider"
STELLAR_SPONSOR_SECRET=""
NFT_REQUIRE_SPONSOR=""
NFT_COLLECTION_WASM_HASH="df42dfceaf2036be527561f313392cee4b756d34745d7cc5f7a1c96936543710"

# Optional De-pin gateway. `npm run dev` starts frontend + NFT API.
# Use `npm run dev:all` when you also want the De-pin gateway.
# Config priority: DEPIN_CONFIG_JSON > DEPIN_CONFIG_URL > DEPIN_CONFIG_PATH
DEPIN_CONFIG_PATH="depin.config.json"
DEPIN_CONFIG_URL=""
DEPIN_CONFIG_JSON=""
# memory (default) | file | redis (not implemented)
DEPIN_STATE_BACKEND="memory"
DEPIN_STATE_PATH=".data/depin-state.json"
# Optional: OZ Channels Bearer key for Stellar x402 settle (required when facilitatorUrl is channels.openzeppelin.com)
OZ_API_KEY=""
# Alias accepted by the gateway:
# X402_FACILITATOR_API_KEY=""
WEATHER_API_TOKEN=""

