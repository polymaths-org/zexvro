{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DynamoGateTable",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:Query",
        "dynamodb:DeleteItem"
      ],
      "Resource": "arn:aws:dynamodb:us-east-1:290294660486:table/zexvro-agent-auth"
    },
    {
      "Sid": "ReadSigningSecret",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret"
      ],
      "Resource": "arn:aws:secretsmanager:us-east-1:290294660486:secret:zexvro/agent-auth/issuer-signing-*"
    }
  ]
}
